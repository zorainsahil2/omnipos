# ─── Supabase ──────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API

# Public anon key — safe to expose in frontend
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...your-anon-key...

# Service Role key — ONLY for Super Admin panel (bypasses RLS)
# NEVER share or commit this. Add to Vercel env vars as well.
# Get from: Supabase Dashboard → Project Settings → API → service_role key
VITE_SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...your-service-role-key...
